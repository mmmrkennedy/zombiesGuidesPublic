<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <!-- SEO Meta Tags -->
        <title>{{ title }}</title>
        <meta name="description" content="{{ description }}">
        <meta name="keywords" content="Call of Duty, Zombies, Easter Egg, Guide, Walkthrough, Quest, Side Quest, Main Quest">
        <meta name="author" content="mmmrkennedy">
        <link rel="canonical" href="https://mmmrkennedy.com{{ page.url }}">

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website">
        <meta property="og:url" content="https://mmmrkennedy.com{{ page.url }}">
        <meta property="og:title" content="{{ title }}">
        <meta property="og:description" content="{{ description }}">
        <meta property="og:image" content="https://mmmrkennedy.com/og_image.webp">
        <meta property="og:site_name" content="mmmrkennedy's Zombies Guides">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:url" content="https://mmmrkennedy.com{{ page.url }}">
        <meta name="twitter:title" content="{{ title }}">
        <meta name="twitter:description" content="{{ description }}">
        <meta name="twitter:image" content="https://mmmrkennedy.com/og_image.webp">

        <!-- Stylesheets -->
        {%- if site.bundled %}
            <link rel="stylesheet" type="text/css" href="/css/bundle.min.css?v={{ site.buildVersion }}">
        {%- else %}
            <link rel="stylesheet" type="text/css" href="/css/styles.css?v={{ site.buildVersion }}">
        {%- endif %}
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
        <link rel="dns-prefetch" href="//ko-fi.com">
        <link rel="preconnect" href="//storage.ko-fi.com">

        <!-- REACT_BUNDLE_MODULEPRELOAD -->

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "{{ title }}",
            "description": "{{ description }}",
            "url": "https://mmmrkennedy.com{{ page.url }}",
            "image": "https://mmmrkennedy.com/og_image.webp",
            "author": {
                "@type": "Person",
                "name": "mmmrkennedy",
                "url": "https://mmmrkennedy.com"
            },
            "publisher": {
                "@type": "Organization",
                "name": "mmmrkennedy's Zombies Guides",
                "url": "https://mmmrkennedy.com"
            },
            "about": {
                "@type": "VideoGame",
                "name": "Call of Duty Zombies"
            }
        }
        </script>
    </head>

    <body data-skip-toc="true">
        <div class="smooth-scroll content-window">
            <h1 class="page-title">Call of Duty Zombies Easter Eggs &amp; Quests Guides</h1>

            <!-- Mobile devices content -->
            <div id="mobileContent" style="display: none">
                <button type="button" class="btn btn--fixed bottom-right" onclick="scrollToTop()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-to-line-icon lucide-arrow-up-to-line">
                        <path d="M5 3h14" />
                        <path d="m18 13-6-6-6 6" />
                        <path d="M12 7v14" />
                    </svg>
                </button>
            </div>

            <!-- Non-mobile devices content -->
            <div id="nonMobileContent" style="display: none">
                <button type="button" class="btn btn--fixed bottom-right" onclick="scrollToTop()">Back to Top</button>
            </div>

            <div class="version-display" data-version="{{ site.buildVersion }}">
                <div class="version-and-toggle">
                    v.<span id="version-number">0</span>
                </div>
            </div>

            <div class="content-container">
                {{ content | safe }}
            </div>

            <div class="kofi-container">
                <a href="https://ko-fi.com/mmmrkennedy" target="_blank" class="kofi-button">
                    <img src="https://storage.ko-fi.com/cdn/brandasset/v2/kofi_symbol.png" alt="Ko-fi" class="kofi-img">
                    Tips (Ko-Fi)
                </a>
            </div>
        </div>

        {%- if site.bundled %}
        <script src="/js/bundle.min.js?v={{ site.buildVersion }}" defer></script>
        {%- else %}
        <script src="/js/core/page-utils.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/navigation/scroll-manager.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/navigation/nav-utils.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/ui/tutorial-system.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/ui/lightbox.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/content/link-processor.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/content/quick-links.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/device/mobile-detection.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/quick-links-utils.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/scripts.js?v={{ site.buildVersion }}" defer></script>
        {%- endif %}
    </body>
</html>
