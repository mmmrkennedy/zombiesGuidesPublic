<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <!-- SEO Meta Tags -->
        <title>{{ title }}</title>
        <meta name="description" content="{{ description }}">
        <meta name="keywords" content="Call of Duty, Zombies, Easter Egg, Guide, Walkthrough, Quest, Side Quest, Main Quest">
        <meta name="author" content="mmmrkennedy">
        <link rel="canonical" href="https://mmmrkennedy.com{{ page.url }}">

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website">
        <meta property="og:url" content="https://mmmrkennedy.com{{ page.url }}">
        <meta property="og:title" content="{{ title }}">
        <meta property="og:description" content="{{ description }}">
        <meta property="og:image" content="https://mmmrkennedy.com/og_image.webp">
        <meta property="og:site_name" content="mmmrkennedy's Zombies Guides">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:url" content="https://mmmrkennedy.com{{ page.url }}">
        <meta name="twitter:title" content="{{ title }}">
        <meta name="twitter:description" content="{{ description }}">
        <meta name="twitter:image" content="https://mmmrkennedy.com/og_image.webp">

        <!-- Stylesheets -->
        {%- if site.bundled %}
            <link rel="stylesheet" type="text/css" href="/css/bundle.min.css?v={{ site.buildVersion }}">
        {%- else %}
            <link rel="stylesheet" type="text/css" href="/css/styles.css?v={{ site.buildVersion }}">
        {%- endif %}
        <!-- Favicon -->
        <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
        <link rel="dns-prefetch" href="//ko-fi.com">
        <link rel="preconnect" href="//storage.ko-fi.com">

        <!-- REACT_BUNDLE_MODULEPRELOAD -->

        <!-- JSON-LD Structured Data -->
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "{{ title }}",
            "description": "{{ description }}",
            "url": "https://mmmrkennedy.com{{ page.url }}",
            "image": "https://mmmrkennedy.com/og_image.webp",
            "author": {
                "@type": "Person",
                "name": "mmmrkennedy",
                "url": "https://mmmrkennedy.com"
            },
            "publisher": {
                "@type": "Organization",
                "name": "mmmrkennedy's Zombies Guides",
                "url": "https://mmmrkennedy.com"
            },
            "about": {
                "@type": "VideoGame",
                "name": "Call of Duty Zombies"
            }
        }
        </script>
    </head>

    <body data-skip-toc="true">
        <div class="tutorial-overlay" id="tutorialOverlay" style="display: none">
            <div class="tutorial-popup">
                <div class="tutorial-confirm" id="tutorialConfirm">
                    <p>Are you sure you want to skip the tutorial?</p>
                    <div class="tutorial-confirm-btns">
                        <button id="confirmYesBtn" class="btn btn--danger">Yes, skip</button>
                        <button id="confirmNoBtn" class="btn">Cancel</button>
                    </div>
                </div>

                <div class="tutorial-header">
                    <h2 id="tutorialTitle">Welcome to Zombies Easter Egg Guides!</h2>
                    <button id="exitBtn" class="tutorial-exit-btn" aria-label="Close tutorial">&times;</button>
                </div>

                <div class="tutorial-pages-container">
                    <div class="tutorial-page" data-page="1">
                        <p>Welcome. Since it's your first time here, here's a quick walkthrough.</p>
                        <p>Our guides offer step-by-step instructions for completing Easter Eggs in various Call of Duty Zombies games.</p>
                    </div>

                    <div class="tutorial-page" data-page="2">
                        <a href="/games/IW/zombies_in_spaceland/pictures/main_ee/alien_example.webp" style="display: none;" data-caption="Example Image 1">Arrow Keyed IMG 1</a>
                        <p>Inside any guide, text shown in <a href="/dog_tut_example.webp" data-width="75%" data-height="75%" data-caption="Example Image 2">blue</a> is a clickable image link, except the links at the top of the page.</p>
                        <p>Clicking opens the image in an on-screen viewer. You can close it by clicking outside the image or hitting the X. Use the left/right arrow keys to move between images.</p>
                        <a href="/games/BO4/alpha_omega/pictures/ray_gun_mark_2/frame/frames_panel.webp" style="display: none;" data-caption="Example Image 3">Arrow Keyed IMG 2</a>
                    </div>

                    <div class="tutorial-page" data-page="3">
                        <p>Links in <a class="link-to-page" href="#">Light Blue</a> will take you to another part of the same page or to a different page on this site.</p>
                        <p>You can always use your browser's back button to return to where you were.</p>
                    </div>

                    <div class="tutorial-page" data-page="4">
                        <p>Links in <a class="external-link" href="https://youtube.com" target="_blank">Green (YouTube)</a> lead to other websites, like YouTube or Reddit.</p>
                        <p>We try to make it clear where each link goes before you click it.</p>
                    </div>

                    <div class="tutorial-page" data-page="5">
                        <p>If you ever need to jump to the top of a guide, just use the "Back to Top" button.</p>
                        <p>Also, the guides are open to anyone who wishes to contribute. Join the <a class="external-link" href="https://discord.com/invite/hQng3Yz48A" target="_blank">Discord Server</a> to start helping out.</p>
                        <p>Thanks for checking out the Website!</p>
                    </div>
                </div>

                <div class="tutorial-navigation">
                    <button id="prevPageBtn" class="btn" disabled>Previous</button>
                    <button id="nextPageBtn" class="btn">Next</button>
                    <button id="finishBtn" class="btn btn--accent" style="display: none;">Finish</button>
                </div>

                <div class="tutorial-progress-container">
                    <div class="tutorial-progress-bar">
                        <div class="tutorial-progress-fill" id="progressFill"></div>
                    </div>
                    <div class="tutorial-progress-text" id="progressText">Loading tutorial... 0%</div>
                </div>
            </div>
        </div>

        <div class="smooth-scroll content-window">
            <h1 class="page-title">Call of Duty Zombies Easter Eggs &amp; Quests Guides</h1>

            <!-- Mobile devices content -->
            <div id="mobile-content">
                <button type="button" class="btn btn--fixed bottom-right" onclick="window.ScrollManager.scrollToTop()" aria-label="Back to Top">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-to-line-icon lucide-arrow-up-to-line" aria-hidden="true">
                        <path d="M5 3h14" />
                        <path d="m18 13-6-6-6 6" />
                        <path d="M12 7v14" />
                    </svg>
                </button>
            </div>

            <!-- Non-mobile devices content -->
            <div id="non-mobile-content">
                <button type="button" class="btn btn--fixed bottom-right" onclick="window.ScrollManager.scrollToTop()">Back to Top</button>
            </div>

            <div class="version-display">
                <div class="version-and-toggle">
                    v.<span>{{ site.buildVersionShort }}</span>
                </div>
            </div>

            <div class="content-container">
                {{ content | safe }}
            </div>

            <div class="kofi-container">
                <a href="https://ko-fi.com/mmmrkennedy" target="_blank" class="kofi-button">
                    <img src="https://storage.ko-fi.com/cdn/brandasset/v2/kofi_symbol.png" alt="Ko-fi" class="kofi-img">
                    Tips (Ko-Fi)
                </a>
            </div>
        </div>

        {%- if site.bundled %}
        <script src="/js/bundle.min.js?v={{ site.buildVersion }}" defer></script>
        {%- else %}
        <script src="/js/core/page-utils.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/navigation/scroll-manager.js?v={{ site.buildVersion }}" defer></script>
<script src="/js/ui/tutorial-system.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/ui/lightbox.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/content/link-processor.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/content/quick-links.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/device/mobile-detection.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/quick-links-utils.js?v={{ site.buildVersion }}" defer></script>
        <script src="/js/scripts.js?v={{ site.buildVersion }}" defer></script>
        {%- endif %}
    </body>
</html>
